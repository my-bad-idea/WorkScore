{
  "name": "work-score",
  "version": "0.1.7",
  "description": "工作智能评分平台 - 日报/周报录入、AI与人工双通道考核、部门岗位标准评分",
  "license": "MIT",
  "author": "Libo Zhang",
  "email": "zhanglibo610@gmail.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/my-bad-idea/WorkScore.git"
  },
  "homepage": "https://github.com/my-bad-idea/WorkScore#readme",
  "main": "dist/main.js",
  "bin": {
    "work-score": "bin/cli.js"
  },
  "files": [
    "dist",
    "public",
    "bin"
  ],
  "scripts": {
    "build:packaged": "node scripts/build-packaged.js",
    "build:npm": "node scripts/build-packaged.js && node scripts/copy-npm-artifacts.js",
